# AgentPulse Environment Variables
# Copy to .env and fill in real values.
# NEVER commit real credentials.

# ─── Agent ───────────────────────────────────────────────────────────────────
AGENTPULSE_CONFIG_PATH=/etc/agentpulse/agentpulse.json
AGENTPULSE_CREDENTIAL_PATH=/etc/agentpulse/credentials.json
AGENTPULSE_STATE_DIR=/var/lib/agentpulse
AGENTPULSE_LOG_DIR=/var/log/agentpulse
AGENTPULSE_CHECKIN_INTERVAL=60
AGENTPULSE_BACKEND_URL=https://api.agentpulse.io
AGENTPULSE_LOG_LEVEL=INFO
AGENTPULSE_DRY_RUN=false

# ─── Backend ─────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8088
DATABASE_URL=sqlite:///var/lib/agentpulse/agentpulse.db
SECRET_KEY=[REDACTED]
ENROLLMENT_SECRET=[REDACTED]

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_SECRET_KEY=[REDACTED]
STRIPE_SECRET_KEY=[REDACTED]
STRIPE_WEBHOOK_SECRET=[REDACTED]
STRIPE_PRICE_ID_MONITOR=[REDACTED]
STRIPE_PRICE_ID_REMEDIATE=[REDACTED]
STRIPE_PRICE_ID_TEAMS=[REDACTED]
DATABASE_URL=[REDACTED]

# ─── Control-plane (Cloudflare Workers) ─────────────────────────────────────
D1_DATABASE_ID=[REDACTED]
CF_ACCOUNT_ID=[REDACTED]
CF_API_TOKEN=[REDACTED]
CONTROL_PLANE_ENCRYPTION_KEY=[REDACTED]

# ─── Observability ──────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=[REDACTED]
