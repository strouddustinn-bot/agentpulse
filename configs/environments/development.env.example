# Development environment variables
# Copy to .env.local — NEVER commit real values

# AgentPulse API
AGENTPULSE_BACKEND_URL=http://localhost:8088
AGENTPULSE_ENROLLMENT_TOKEN=dev-token-replace-me

# Agent
AGENTPULSE_LOG_LEVEL=DEBUG
AGENTPULSE_DRY_RUN=true
AGENTPULSE_STATE_DIR=/tmp/agentpulse-dev
AGENTPULSE_LOG_DIR=/tmp/agentpulse-dev/logs

# Backend
DATABASE_URL=sqlite:///tmp/agentpulse-dev/agentpulse.db
SECRET_KEY=dev-secret-key-not-for-production
ENROLLMENT_SECRET=dev-enrollment-secret

# Dashboard
DASHBOARD_SECRET_KEY=dev-dashboard-secret
FLASK_ENV=development
FLASK_DEBUG=1
