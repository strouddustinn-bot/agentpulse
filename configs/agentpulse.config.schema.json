{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentpulse.io/schemas/agentpulse.config.schema.json",
  "title": "AgentPulse Agent Configuration",
  "description": "Schema for the AgentPulse agent configuration file. All paths support variable substitution with ${ENV_VAR} syntax.",
  "type": "object",
  "required": ["version", "control_plane", "checks"],
  "additionalProperties": false,
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "positiveFloat": {
      "type": "number",
      "minimum": 0
    },
    "filePath": {
      "type": "string",
      "pattern": "^(/|[a-zA-Z]:\\\\|\\$\\{)"
    },
    "urlString": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://"
    },
    "logLevel": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
    },
    "policyMode": {
      "type": "string",
      "enum": ["alert_only", "ask", "auto"]
    }
  },
  "properties": {
    "version": {
      "type": "string",
      "const": "1",
      "description": "Config format version. Must be '1'."
    },
    "control_plane": {
      "type": "object",
      "required": ["backend_url", "enrollment_token", "auth_token"],
      "additionalProperties": false,
      "properties": {
        "backend_url": {
          "$ref": "#/definitions/urlString",
          "description": "Base URL of the AgentPulse control-plane API."
        },
        "enrollment_token": {
          "type": "string",
          "minLength": 16,
          "description": "One-time enrollment token from the dashboard."
        },
        "auth_token": {
          "type": "string",
          "minLength": 16,
          "description": "HMAC secret for signing check-in payloads."
        },
        "checkin_interval": {
          "$ref": "#/definitions/positiveInteger",
          "default": 60,
          "description": "Seconds between check-ins. Minimum 30."
        },
        "heartbeat_timeout": {
          "$ref": "#/definitions/positiveInteger",
          "default": 300,
          "description": "Seconds to wait for a heartbeat response before queuing offline."
        },
        "offline_queue_dir": {
          "$ref": "#/definitions/filePath",
          "description": "Directory for queued payloads when offline. Default: ${AGENTPULSE_STATE_DIR}/spool"
        },
        "offline_queue_max_bytes": {
          "$ref": "#/definitions/positiveInteger",
          "default": 5242880,
          "description": "Maximum total size of offline spool. Default: 5 MiB."
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/checkDefinition"
      },
      "minProperties": 1,
      "description": "Map of check ID to check configuration. IDs must be alphanumeric with underscores."
    },
    "policy": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/definitions/policyMode"
        },
        "max_remediations_per_hour": {
          "$ref": "#/definitions/positiveInteger",
          "default": 10
        },
        "ceiling_severity": {
          "type": "string",
          "enum": ["warning", "critical"],
          "default": "warning"
        },
        "cooldown_seconds": {
          "$ref": "#/definitions/nonNegativeInteger",
          "default": 300
        },
        "dedupe_window_seconds": {
          "$ref": "#/definitions/nonNegativeInteger",
          "default": 600
        },
        "maintenance_windows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["begin", "end", "days"],
            "additionalProperties": false,
            "properties": {
              "begin": { "type": "string", "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$" },
              "end": { "type": "string", "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$" },
              "days": {
                "type": "array",
                "items": { "type": "string", "enum": ["mon","tue","wed","thu","fri","sat","sun"] },
                "minItems": 1
              },
              "timezone": { "type": "string", "default": "UTC" }
            }
          },
          "default": []
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "min_samples": { "$ref": "#/definitions/positiveInteger", "default": 20 },
        "z_threshold": { "type": "number", "minimum": 0.1, "default": 3.0 },
        "min_abs_deviation": { "type": "number", "minimum": 0, "default": 2.0 }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": { "$ref": "#/definitions/logLevel" },
        "file": { "$ref": "#/definitions/filePath" },
        "max_bytes": { "$ref": "#/definitions/positiveInteger", "default": 10485760 },
        "backup_count": { "$ref": "#/definitions/positiveInteger", "default": 5 },
        "redact": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["password", "token", "secret", "key", "credential"]
        }
      }
    },
    "state_dir": {
      "$ref": "#/definitions/filePath",
      "description": "Directory for agent state DB and baselines. Default: /var/lib/agentpulse"
    },
    "dev_mode": {
      "type": "boolean",
      "default": false,
      "description": "When true, enables verbose logging and disables credential file requirement."
    }
  },
  "definitions": {
    "checkDefinition": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "disk", "memory", "cpu", "load", "uptime",
            "process", "systemd", "docker", "http",
            "port", "tls_cert", "file", "command",
            "inodes", "mounts", "network"
          ],
          "description": "Check type. Custom command checks use type 'command'."
        },
        "enabled": { "type": "boolean", "default": true },
        "interval": { "$ref": "#/definitions/positiveInteger", "description": "Override global interval for this check." },
        "warning_threshold": { "$ref": "#/definitions/positiveFloat" },
        "critical_threshold": { "$ref": "#/definitions/positiveFloat" },
        "consecutive_required": { "$ref": "#/definitions/positiveInteger", "default": 1 },
        "cooldown_seconds": { "$ref": "#/definitions/nonNegativeInteger" },
        "remediation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "action": {
              "type": "string",
              "enum": ["restart_service", "restart_container", "rotate_logs", "clean_temp", "prune_cache"],
              "description": "Remediation action to dispatch when this check fails critically."
            },
            "target": { "type": "string", "description": "Target for the remediation action (e.g. service name)." },
            "requires_approval": { "type": "boolean", "default": false },
            "risk": { "type": "string", "enum": ["low", "medium", "high"], "default": "low" }
          }
        },
        "command": { "type": "string", "description": "Required for type=command. Shell command to execute." },
        "timeout": { "$ref": "#/definitions/positiveInteger", "default": 10, "description": "Command timeout in seconds." },
        "expected_output": { "type": "string", "description": "Substring that must appear in stdout for the check to pass." },
        "path": { "type": "string", "description": "Path for disk/file/path checks." },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "description": "Port for port/tls_cert checks." },
        "hostname": { "type": "string", "description": "Hostname for http/port checks." }
      }
    }
  }
}
