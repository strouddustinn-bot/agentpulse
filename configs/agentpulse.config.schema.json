{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentpulse.ca/schemas/agentpulse.config.schema.json",
  "title": "AgentPulse Agent Configuration",
  "description": "Configuration contract for the dependency-light AgentPulse local agent.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "hostname": {
      "type": "string",
      "minLength": 1
    },
    "interval_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "state_file": {
      "type": "string",
      "minLength": 1
    },
    "log_file": {
      "type": "string",
      "minLength": 1
    },
    "notify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "stdout",
            "webhook"
          ]
        },
        "webhook_url": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https?://"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "webhook"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "webhook_url": {
                "type": "string",
                "format": "uri",
                "pattern": "^https?://"
              }
            },
            "required": [
              "webhook_url"
            ]
          }
        }
      ]
    },
    "checkin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endpoint_url": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https?://"
            }
          ]
        },
        "auth_token": {
          "type": "string"
        },
        "timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "identity_file": {
          "type": "string",
          "minLength": 1
        },
        "credential_file": {
          "type": "string",
          "minLength": 1
        },
        "spool_directory": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "control_plane": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "base_url": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https?://"
            }
          ]
        },
        "credential_file": {
          "type": "string",
          "minLength": 1
        },
        "spool_directory": {
          "type": "string",
          "minLength": 1
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "local_policy_ceiling": {
          "type": "string",
          "enum": [
            "off",
            "alert",
            "ask",
            "auto"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": [
              "enabled"
            ]
          },
          "then": {
            "properties": {
              "base_url": {
                "type": "string",
                "format": "uri",
                "pattern": "^(https://|http://(localhost|127\\.0\\.0\\.1|\\[::1\\])(?=[:/]|$))"
              }
            },
            "required": [
              "base_url"
            ]
          }
        }
      ]
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "min_samples": {
          "type": "integer",
          "minimum": 1
        },
        "z_threshold": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "min_abs_deviation": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ml_enabled": {
          "type": "boolean"
        },
        "hw_alpha": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "hw_beta": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disk": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "off",
                "alert",
                "ask",
                "auto"
              ]
            },
            "threshold_percent": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 100
            },
            "paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cleanup_globs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cleanup_older_than_days": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "mode": {
                    "const": "auto"
                  }
                },
                "required": [
                  "mode"
                ]
              },
              "then": {
                "properties": {
                  "cleanup_globs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "minItems": 1
                  }
                },
                "required": [
                  "cleanup_globs"
                ]
              }
            }
          ]
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "off",
                "alert",
                "ask",
                "auto"
              ]
            },
            "services": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "process": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "off",
                "alert",
                "ask",
                "auto"
              ]
            },
            "mem_percent_threshold": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 100
            }
          }
        }
      }
    },
    "_note": {
      "type": "string"
    },
    "_comments": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
