{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentpulse.ca/contracts/schemas/audit-event.schema.json",
  "title": "Audit Event",
  "description": "Immutable event record for compliance and debugging.",
  "type": "object",
  "required": ["id", "timestamp", "component", "event_type", "actor"],
  "additionalProperties": true,
  "properties": {
    "id":          { "type": "string", "format": "uuid" },
    "timestamp":   { "type": "string", "format": "date-time" },
    "component":   { "type": "string", "enum": ["agent","backend","worker","dashboard","control-plane"] },
    "event_type":  { "type": "string" },
    "actor":       { "type": "string", "description": "user:<id>, agent:<id>, or system" },
    "agent_id":    { "type": ["string","null"], "format": "uuid" },
    "incident_id":  { "type": ["string","null"], "format": "uuid" },
    "remediation_id": { "type": ["string","null"], "format": "uuid" },
    "outcome":     { "type": ["string","null"], "enum": ["success","failure","pending","suppressed"] },
    "body":        { "type": "object", "description": "Event-specific structured payload." },
    "redacted":    { "type": "array", "items": { "type": "string" }, "description": "Keys that were redacted from body before transmission." }
  }
}
