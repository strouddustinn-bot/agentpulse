{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentpulse.io/contracts/schemas/incident.schema.json",
  "title": "Incident",
  "description": "Anomaly or failure detected on a monitored server.",
  "type": "object",
  "required": ["id", "agent_id", "check_id", "status", "severity", "opened_at"],
  "additionalProperties": false,
  "properties": {
    "id":           { "type": "string", "format": "uuid" },
    "agent_id":     { "type": "string", "format": "uuid" },
    "check_id":     { "type": "string" },
    "check_type":   { "type": "string" },
    "status":       { "type": "string", "enum": ["open","acknowledged","resolved","suppressed"] },
    "severity":     { "type": "string", "enum": ["info","warning","critical"] },
    "title":        { "type": "string" },
    "body":         { "type": "string" },
    "evidence":     { "type": "array", "items": { "type": "string" } },
    "opened_at":    { "type": "string", "format": "date-time" },
    "acknowledged_at": { "type": ["string","null"], "format": "date-time" },
    "acknowledged_by": { "type": ["string","null"] },
    "resolved_at":   { "type": ["string","null"], "format": "date-time" },
    "resolved_by":   { "type": ["string","null"] },
    "remediation_id": { "type": ["string","null"], "format": "uuid" },
    "policy_id":     { "type": ["string","null"] },
    "is_baseline_anomaly": { "type": "boolean" },
    "tags":         { "type": "array", "items": { "type": "string" } }
  }
}
