{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentpulse.ca/contracts/schemas/incident.schema.json",
  "title": "Fleet Incident",
  "description": "A bounded incident materialized by the control plane from an agent heartbeat.",
  "type": "object",
  "required": ["id", "fingerprint", "kind", "status", "severity", "detail", "opened_at", "updated_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "fingerprint": { "type": "string", "minLength": 1, "maxLength": 255 },
    "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
    "status": { "type": "string", "enum": ["open", "resolved", "escalated"] },
    "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
    "detail": { "type": "string", "maxLength": 2048 },
    "opened_at": { "type": "integer" },
    "updated_at": { "type": "integer" }
  }
}
