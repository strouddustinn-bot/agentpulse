{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentpulse.io/contracts/schemas/enrollment.schema.json",
  "title": "Agent Enrollment",
  "description": "Payload sent when an agent first enrolls with the control plane.",
  "type": "object",
  "required": ["version", "hostname", "os", "architecture", "agent_version", "config_version", "timestamp", "signature"],
  "additionalProperties": false,
  "properties": {
    "version":     { "type": "string", "const": "1" },
    "hostname":    { "type": "string", "minLength": 1, "maxLength": 255 },
    "os":          { "type": "string", "enum": ["linux", "darwin", "freebsd", "windows"] },
    "architecture": { "type": "string", "enum": ["amd64", "arm64", "x86", "armv7"] },
    "agent_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
    "config_version": { "type": "string" },
    "kernel_version": { "type": "string" },
    "boot_id":     { "type": "string" },
    "machine_id":  { "type": "string" },
    "checks_offered": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of check types the agent is capable of executing."
    },
    "timestamp":   { "type": "string", "format": "date-time" },
    "nonce":       { "type": "string", "minLength": 16, "description": "Replay-resistance nonce generated by the agent." },
    "enrollment_token": { "type": "string", "minLength": 16 },
    "signature":   { "type": "string", "description": "HMAC-SHA256(agent_id + nonce + timestamp, auth_token)" }
  }
}
